<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard | Admin PodWave</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <style>
        body { background-color: #f4f6f9; }
        .stat-card { border: none; border-radius: 12px; transition: transform 0.2s; box-shadow: 0 4px 6px rgba(0,0,0,0.04); }
        .stat-card:hover { transform: translateY(-5px); }
        .icon-box { width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top shadow-sm">
        <div class="container-fluid px-lg-4">
            <a class="navbar-brand fw-bold" href="/admin/dashboard">PodWave <span class="badge bg-primary ms-2" style="font-size: 0.6rem;">ADMIN</span></a>
            <div class="d-flex align-items-center">
                <a href="/feed" class="btn btn-sm btn-outline-light"><i class="bi bi-arrow-left me-1"></i> Sair do Admin</a>
            </div>
        </div>
    </nav>

    <div class="container-fluid">
        <div class="row">
            <aside class="col-md-3 col-lg-2 bg-white border-end min-vh-100 py-4 d-none d-md-block">
                <nav class="nav flex-column gap-2 px-2">
                    <a class="nav-link active bg-light rounded text-dark fw-bold" href="/admin/dashboard"><i class="bi bi-speedometer2 me-2 text-primary"></i> Dashboard</a>
                    <a class="nav-link text-dark" href="/admin/users"><i class="bi bi-people me-2"></i> Usuários</a>
                    <a class="nav-link text-dark" href="/upload"><i class="bi bi-cloud-arrow-up me-2"></i> Adicionar Podcast</a>
                </nav>
            </aside>

            <main class="col-md-9 col-lg-10 py-4 px-lg-5">
                <h3 class="fw-bold mb-4">Bem-vindo, <%= user.username %>!</h3>

                <div class="row g-4 mb-5">
                    <div class="col-12 col-md-4">
                        <div class="card stat-card p-3 d-flex flex-row align-items-center">
                            <div class="icon-box bg-primary bg-opacity-10 text-primary me-3"><i class="bi bi-people-fill"></i></div>
                            <div>
                                <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 0.7rem;">Usuários</small>
                                <h4 class="fw-bold mb-0"><%= stats.users %></h4>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-md-4">
                        <div class="card stat-card p-3 d-flex flex-row align-items-center">
                            <div class="icon-box bg-success bg-opacity-10 text-success me-3"><i class="bi bi-mic-fill"></i></div>
                            <div>
                                <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 0.7rem;">Podcasts</small>
                                <h4 class="fw-bold mb-0"><%= stats.podcasts %></h4>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-md-4">
                        <div class="card stat-card p-3 d-flex flex-row align-items-center">
                            <div class="icon-box bg-danger bg-opacity-10 text-danger me-3"><i class="bi bi-heart-fill"></i></div>
                            <div>
                                <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 0.7rem;">Favoritos</small>
                                <h4 class="fw-bold mb-0"><%= stats.favorites %></h4>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white py-3 fw-bold">Últimos Adicionados</div>
                    <div class="card-body p-0">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Título</th>
                                    <th>Categoria</th>
                                    <th>Data</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (podcasts && podcasts.length > 0) { %>
                                    <% podcasts.forEach(p => { %>
                                        <tr>
                                            <td class="ps-4 fw-semibold"><%= p.title %></td>
                                            <td><span class="badge bg-secondary"><%= p.category %></span></td>
                                            <td><%= new Date(p.createdAt).toLocaleDateString('pt-BR') %></td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr><td colspan="3" class="text-center py-3 text-muted">Nenhum podcast encontrado.</td></tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </main>
        </div>
    </div>
</body>
</html>