<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Gerenciar Usuários</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
</head>
<body class="bg-light">
    <div class="container py-5">
        <a href="/admin/dashboard" class="btn btn-outline-secondary mb-3"><i class="bi bi-arrow-left"></i> Voltar</a>
        <h3 class="fw-bold mb-4">Gerenciamento de Usuários</h3>
        
        <div class="table-responsive bg-white rounded shadow-sm p-3">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Usuário</th>
                        <th>Email</th>
                        <th>Nível</th>
                        <th class="text-center">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    <% users.forEach(u => { %>
                    <tr>
                        <td><%= u.username %></td>
                        <td><%= u.email %></td>
                        <td>
                            <span class="badge <%= u.role === 'admin' ? 'bg-danger' : 'bg-primary' %>">
                                <%= u.role.toUpperCase() %>
                            </span>
                        </td>
                        <td class="text-center">
                            <button class="btn btn-sm btn-outline-dark toggle-role" data-id="<%= u.id %>">
                                <i class="bi bi-shield-lock"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-danger delete-user" data-id="<%= u.id %>">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>

    <script>
        // Função para Alternar Permissão com Confirmação
        document.querySelectorAll('.toggle-role').forEach(btn => {
            btn.addEventListener('click', async function() {
                if(confirm('Tem certeza que deseja alterar o nível de acesso deste usuário?')) {
                    const res = await fetch('/admin/users/toggle-admin', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ userId: this.dataset.id })
                    });
                    if (res.ok) location.reload();
                }
            });
        });

        // Função para Deletar com Confirmação
        document.querySelectorAll('.delete-user').forEach(btn => {
            btn.addEventListener('click', async function() {
                if(confirm('ATENÇÃO: Você deseja excluir este usuário permanentemente? Esta ação é irreversível.')) {
                    const res = await fetch('/admin/users/delete', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ userId: this.dataset.id })
                    });
                    if (res.ok) location.reload();
                    else alert('Erro ao deletar!');
                }
            });
        });
    </script>
</body>
</html>