<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | PodWave</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>

<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-light bg-white sticky-top shadow-sm">
        <div class="container-fluid px-lg-5">
            <a class="navbar-brand fw-bold text-primary" href="/feed"><i class="bi bi-mic-fill"></i> PODWAVE</a>
            <div class="d-flex align-items-center ms-auto">
                <div class="dropdown">
                    <a href="#" class="d-block link-dark text-decoration-none dropdown-toggle" id="dropdownUser" data-bs-toggle="dropdown" aria-expanded="false">
                        <span class="me-2 d-none d-md-inline small fw-semibold">@<%= user.username %></span>
                        <img src="<%= (user.profilePicture && user.profilePicture !== 'default-profile.png') ? '/uploads/profiles/' + user.profilePicture : 'https://ui-avatars.com/api/?name=' + user.username + '&background=4f46e5&color=fff' %>" 
                        alt="Avatar" width="32" height="32" class="rounded-circle object-fit-cover bg-secondary">
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end text-small shadow border-0 mt-2">
                        <li><a class="dropdown-item py-2" href="/profile/edit"><i class="bi bi-person me-2"></i> Meu Perfil</a></li>
                        <li><a class="dropdown-item py-2 text-danger" href="/logout"><i class="bi bi-box-arrow-right me-2"></i> Sair</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </nav>

    <div class="container-fluid px-lg-5">
        <div class="row">
            <aside class="col-md-3 col-lg-2 d-none d-md-block sidebar py-4 bg-white min-vh-100 border-end">
                <nav class="nav flex-column">
                    <a class="nav-link text-dark" href="/feed"><i class="bi bi-house-door me-2"></i> Início</a>
                    <a class="nav-link text-dark" href="/categories"><i class="bi bi-grid me-2"></i> Categorias</a>
                    <a class="nav-link text-dark" href="/explore"><i class="bi bi-compass me-2"></i> Explorar</a>
                    <hr>
                    <p class="small text-muted px-3 mb-2 fw-bold text-uppercase">Sua Biblioteca</p>
                    <a class="nav-link text-dark py-2" href="/continue"><i class="bi bi-play-circle me-2"></i> Continuar Ouvindo</a>
                    <a class="nav-link active fw-bold text-danger py-2" href="/favorites"><i class="bi bi-heart-fill me-2"></i> Favoritos</a>
                    <a class="nav-link text-dark py-2" href="/history"><i class="bi bi-clock-history me-2"></i> Histórico</a>
                </nav>
            </aside>

            <main class="col-12 col-md-9 col-lg-10 py-4">
                <div class="d-flex align-items-center mb-4 pb-2 border-bottom">
                    <i class="bi bi-heart-fill fs-3 text-danger me-3"></i>
                    <h4 class="fw-bold mb-0">Meus Episódios Favoritos</h4>
                    <span class="badge bg-light text-dark border ms-3"><%= favoriteIds.length %> salvos</span>
                </div>

                <div class="row g-4">
                    
                    <% 
                        // Converte todos os IDs do banco para String para garantir que o .includes() funcione
                        const safeFavoriteIds = favoriteIds.map(String); 
                    %>

                    <% if (safeFavoriteIds.length === 0) { %>
                        <div class="col-12 text-center py-5">
                            <i class="bi bi-heartbreak text-muted mb-3" style="font-size: 4rem;"></i>
                            <h5 class="text-muted fw-bold">Você ainda não tem episódios favoritos.</h5>
                            <p class="text-muted">Navegue pelo feed e clique no coração para salvar seus podcasts preferidos aqui.</p>
                            <a href="/feed" class="btn btn-primary mt-3 px-4 rounded-pill">Explorar Podcasts</a>
                        </div>
                    <% } %>

                    <% if (safeFavoriteIds.includes('101')) { %>
                    <div class="col-12 col-sm-6 col-md-4 col-xl-3">
                        <div class="podcast-card">
                            <div class="cover-placeholder" style="background-color: #1a1a2e;">
                                <i class="bi bi-code-slash text-info"></i>
                                <i class="bi bi-heart-fill text-danger position-absolute top-0 end-0 m-3 fs-5 favorite-btn" data-id="101" style="cursor: pointer;"></i>
                            </div>
                            <div class="p-3">
                                <h6 class="text-truncate mb-1 fw-bold">Hipsters #400 - O Futuro do Front-end</h6>
                                <p class="text-muted small mb-3">Hipsters Ponto Tech</p>
                                <button class="btn btn-sm btn-outline-primary rounded-circle"><i class="bi bi-play-fill"></i></button>
                            </div>
                        </div>
                    </div>
                    <% } %>

                    <% if (safeFavoriteIds.includes('102')) { %>
                    <div class="col-12 col-sm-6 col-md-4 col-xl-3">
                        <div class="podcast-card">
                            <div class="cover-placeholder" style="background-color: #000;">
                                <i class="bi bi-rocket-takeoff text-warning"></i>
                                <i class="bi bi-heart-fill text-danger position-absolute top-0 end-0 m-3 fs-5 favorite-btn" data-id="102" style="cursor: pointer;"></i>
                            </div>
                            <div class="p-3">
                                <h6 class="text-truncate mb-1 fw-bold">NerdCast 920 - A Inteligência Artificial...</h6>
                                <p class="text-muted small mb-3">Jovem Nerd</p>
                                <button class="btn btn-sm btn-outline-primary rounded-circle"><i class="bi bi-play-fill"></i></button>
                            </div>
                        </div>
                    </div>
                    <% } %>

                    <% if (safeFavoriteIds.includes('103')) { %>
                    <div class="col-12 col-sm-6 col-md-4 col-xl-3">
                        <div class="podcast-card">
                            <div class="cover-placeholder" style="background-color: #d32f2f;">
                                <i class="bi bi-laptop text-white"></i>
                                <i class="bi bi-heart-fill text-danger position-absolute top-0 end-0 m-3 fs-5 favorite-btn" data-id="103" style="cursor: pointer;"></i>
                            </div>
                            <div class="p-3">
                                <h6 class="text-truncate mb-1 fw-bold">Tecnocast 298 - Lançamentos da Apple</h6>
                                <p class="text-muted small mb-3">Tecnoblog</p>
                                <button class="btn btn-sm btn-outline-primary rounded-circle"><i class="bi bi-play-fill"></i></button>
                            </div>
                        </div>
                    </div>
                    <% } %>

                    <% if (safeFavoriteIds.includes('104')) { %>
                    <div class="col-12 col-sm-6 col-md-4 col-xl-3">
                        <div class="podcast-card">
                            <div class="cover-placeholder" style="background-color: #2e7d32;">
                                <i class="bi bi-controller text-white"></i>
                                <i class="bi bi-heart-fill text-danger position-absolute top-0 end-0 m-3 fs-5 favorite-btn" data-id="104" style="cursor: pointer;"></i>
                            </div>
                            <div class="p-3">
                                <h6 class="text-truncate mb-1 fw-bold">99Vidas 550 - A História do PS2</h6>
                                <p class="text-muted small mb-3">99Vidas</p>
                                <button class="btn btn-sm btn-outline-primary rounded-circle"><i class="bi bi-play-fill"></i></button>
                            </div>
                        </div>
                    </div>
                    <% } %>

                </div>
            </main>
        </div>
    </div>
    
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const favoriteButtons = document.querySelectorAll('.favorite-btn');

            favoriteButtons.forEach(btn => {
                btn.addEventListener('click', async function() {
                    const podcastId = this.getAttribute('data-id');
                    
                    try {
                        const response = await fetch('/api/favorites/toggle', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ podcastId: podcastId })
                        });

                        const result = await response.json();
                        if (result.success) {
                            // Se desfavoritou com sucesso, recarrega a página para sumir com o card
                            window.location.reload();
                        }
                    } catch (error) {
                        console.error('Erro:', error);
                    }
                });
            });
        });
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>