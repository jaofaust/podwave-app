<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Feed | PodWave</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/stylesheets/style.css">
    <style>
        /* Ajuste para garantir que as capas enviadas fiquem centralizadas e profissionais */
        .podcast-cover-img {
            width: 100%;
            height: 220px;
            object-fit: cover;
            border-radius: 12px 12px 0 0;
        }
        .podcast-card {
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.02);
            transition: transform 0.2s;
            overflow: hidden;
        }
        .podcast-card:hover { transform: translateY(-4px); }
        .cover-wrapper { position: relative; }
        .play-overlay {
            position: absolute;
            top: 0; left: 0; w: 100%; height: 100%;
            background: rgba(0,0,0,0.4);
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transition: opacity 0.2s;
            width: 100%;
        }
        .cover-wrapper:hover .play-overlay { opacity: 1; }
    </style>
</head>

<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-light bg-white sticky-top shadow-sm">
        <div class="container-fluid px-lg-5">
            <a class="navbar-brand fw-bold text-primary" href="/feed">
                <i class="bi bi-mic-fill"></i> PODWAVE
            </a>

            <form class="d-none d-md-flex mx-auto" style="width: 40%;">
                <div class="input-group">
                    <input type="text" class="form-control bg-light border-0"
                        placeholder="Pesquisar podcasts, episódios ou criadores..." style="border-radius: 20px 0 0 20px;">
                    <button class="btn btn-light border-0" type="button" style="border-radius: 0 20px 20px 0;">
                        <i class="bi bi-search"></i>
                    </button>
                </div>
            </form>

            <div class="d-flex align-items-center">
                <a href="/upload" class="btn btn-outline-primary border-0 me-3 d-none d-sm-block fw-semibold">
    <i class="bi bi-cloud-arrow-up me-1"></i> Publicar
</a>
                <div class="dropdown">
                    <a href="#" class="d-block link-dark text-decoration-none dropdown-toggle" id="dropdownUser"
                        data-bs-toggle="dropdown" aria-expanded="false">
                        <span class="me-2 d-none d-md-inline small fw-semibold">@<%= user ? user.username : 'visitante' %></span>
                        <img src="<%= (user && user.profilePicture && user.profilePicture !== 'default-profile.png') ? '/uploads/profiles/' + user.profilePicture : 'https://ui-avatars.com/api/?name=' + (user ? user.username : 'User') + '&background=4f46e5&color=fff' %>" 
     alt="Avatar" width="32" height="32" class="rounded-circle object-fit-cover bg-secondary">
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end text-small shadow border-0 mt-2" aria-labelledby="dropdownUser">
                        <% if (user && user.role === 'admin') { %>
                            <li>
                                <a class="dropdown-item py-2 text-primary fw-bold bg-primary bg-opacity-10" href="/admin/dashboard">
                                    <i class="bi bi-speedometer2 me-2"></i> Painel Admin
                                </a>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                        <% } %>
                        <li><a class="dropdown-item py-2" href="/profile/edit"><i class="bi bi-person me-2"></i> Meu Perfil</a></li>
                        <li><a class="dropdown-item py-2 text-danger" href="/logout"><i class="bi bi-box-arrow-right me-2"></i> Sair</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </nav>

    <div class="container-fluid px-lg-5">
        <div class="row">
            <aside class="col-md-3 col-lg-2 d-none d-md-block sidebar py-4 bg-white min-vh-100 border-end">
                <nav class="nav flex-column">
                    <a class="nav-link active fw-bold text-primary" href="/feed"><i class="bi bi-house-door-fill me-2"></i> Início</a>
                    <a class="nav-link text-dark" href="/categories"><i class="bi bi-grid me-2"></i> Categorias</a>
                    <a class="nav-link text-dark" href="/explore"><i class="bi bi-compass me-2"></i> Explorar</a>
                    <hr>
                    <p class="small text-muted px-3 mb-2 fw-bold text-uppercase">Sua Biblioteca</p>
                    <a class="nav-link text-dark py-2" href="/continue"><i class="bi bi-play-circle me-2"></i> Continuar Ouvindo</a>
                    <a class="nav-link text-dark py-2" href="/favorites"><i class="bi bi-heart-fill text-danger me-2"></i> Favoritos</a>
                    <a class="nav-link text-dark py-2" href="/history"><i class="bi bi-clock-history me-2"></i> Histórico</a>
                </nav>
            </aside>

            <main class="col-12 col-md-9 col-lg-10 py-4">
                
                <div class="d-flex gap-2 mb-4 overflow-auto pb-2" style="white-space: nowrap;">
                    <button class="btn btn-dark rounded-pill px-4">Todos</button>
                    <button class="btn btn-outline-secondary bg-white rounded-pill px-4">Tecnologia</button>
                    <button class="btn btn-outline-secondary bg-white rounded-pill px-4">Negócios</button>
                    <button class="btn btn-outline-secondary bg-white rounded-pill px-4">Educação</button>
                    <button class="btn btn-outline-secondary bg-white rounded-pill px-4">Entrevistas</button>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4 class="fw-bold mb-0">Explorar Catálogo</h4>
                </div>

<div class="row g-4">
    <% if (podcasts && podcasts.length > 0) { %>
        <% podcasts.forEach(podcast => { %>
            <div class="col-12 col-sm-6 col-md-4 col-xl-3">
                <div class="podcast-card">
                    <div class="cover-wrapper">
                        <img src="/uploads/covers/<%= podcast.coverUrl %>" class="podcast-cover-img" alt="Capa do Episódio">
                        
<div class="play-overlay" 
     data-audio="/uploads/audio/<%= podcast.audioUrl %>" 
     data-author="<%= podcast.author %>" 
     data-cover="/uploads/covers/<%= podcast.coverUrl %>">
    <i class="bi bi-play-circle-fill text-white" style="font-size: 3.5rem; cursor: pointer;"></i>
</div>
                    </div>
                    
                    <div class="p-3">
                        <div class="d-flex justify-content-between align-items-start mb-1">
                            <h6 class="text-truncate mb-0 fw-bold" style="max-width: 85%;" title="<%= podcast.title %>"><%= podcast.title %></h6>
                            <i class="bi <%= favoriteIds && favoriteIds.includes(podcast.id.toString()) ? 'bi-heart-fill text-danger' : 'bi-heart text-muted' %> favorite-btn" data-id="<%= podcast.id %>" style="cursor: pointer;"></i>
                        </div>
                        <div class="text-muted small mb-2"><%= podcast.author %></div>
                        
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="badge bg-light text-dark text-capitalize px-2 py-1" style="font-size: 0.75rem;"><%= podcast.category %></span>
                            <div class="text-muted small" style="font-size: 0.75rem;"><i class="bi bi-calendar3 me-1"></i><%= new Date(podcast.createdAt).toLocaleDateString('pt-BR') %></div>
                        </div>
                    </div>
                </div>
            </div>
        <% }) %>
    <% } else { %>
        <div class="col-12 text-center py-5">
            <i class="bi bi-mic text-muted" style="font-size: 3rem;"></i>
            <p class="text-muted mt-3">Nenhum podcast publicado no catálogo ainda.</p>
        </div>
    <% } %>
</div>
    <div class="fixed-bottom bg-white border-top shadow-lg p-3" id="audio-player-container" style="display: none; z-index: 1050;">
        <div class="container-fluid px-lg-5 d-flex align-items-center justify-content-between">
            <div class="d-flex align-items-center" style="width: 30%;">
                <img id="player-cover-img" src="" class="rounded me-3 bg-dark object-fit-cover" style="width: 48px; height: 48px; display: none;">
                <div id="player-cover-placeholder" class="bg-dark rounded text-white d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px;">
                    <i class="bi bi-mic"></i>
                </div>
                <div class="overflow-hidden">
                    <h6 class="mb-0 fw-bold text-truncate" id="player-title">Título do Episódio</h6>
                    <small class="text-muted text-truncate d-block" id="player-author">Autor</small>
                </div>
            </div>

            <div class="d-flex flex-column align-items-center" style="width: 40%;">
                <div class="d-flex align-items-center gap-3 mb-2">
                    <i class="bi bi-skip-backward-fill fs-5 text-muted" style="cursor: pointer;"></i>
                    <button class="btn btn-primary rounded-circle d-flex align-items-center justify-content-center" id="play-pause-btn" style="width: 40px; height: 40px;">
                        <i class="bi bi-play-fill fs-4" id="play-icon"></i>
                    </button>
                    <i class="bi bi-skip-forward-fill fs-5 text-muted" style="cursor: pointer;"></i>
                </div>
                <div class="d-flex align-items-center w-100 gap-2">
                    <small class="text-muted" id="time-current">0:00</small>
                    <input type="range" class="form-range flex-grow-1" id="seek-bar" value="0" step="1">
                    <small class="text-muted" id="time-total">0:00</small>
                </div>
            </div>

            <div class="d-flex align-items-center justify-content-end gap-2" style="width: 30%;">
                <i class="bi bi-volume-up text-muted"></i>
                <input type="range" class="form-range w-50" id="volume-bar" min="0" max="1" step="0.05" value="1">
            </div>

            <audio id="main-audio" src=""></audio>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Sistema de Favoritar Dinâmico via API
            const favoriteButtons = document.querySelectorAll('.favorite-btn');
            favoriteButtons.forEach(btn => {
                btn.addEventListener('click', async function() {
                    const podcastId = this.getAttribute('data-id');
                    try {
                        const response = await fetch('/api/favorites/toggle', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ podcastId: podcastId })
                        });
                        const result = await response.json();
                        if (result.success) {
                            if (result.action === 'added') {
                                this.classList.remove('bi-heart', 'text-muted');
                                this.classList.add('bi-heart-fill', 'text-danger');
                            } else if (result.action === 'removed') {
                                this.classList.remove('bi-heart-fill', 'text-danger');
                                this.classList.add('bi-heart', 'text-muted');
                            }
                        } else {
                            alert(result.message || 'Erro ao processar ação.');
                        }
                    } catch (error) {
                        console.error('Erro na requisição:', error);
                    }
                });
            });

            // Controle de Execução Real do Audio Player
            const audio = document.getElementById('main-audio');
            const playPauseBtn = document.getElementById('play-pause-btn');
            const playIcon = document.getElementById('play-icon');
            const seekBar = document.getElementById('seek-bar');
            const volumeBar = document.getElementById('volume-bar');
            const timeCurrent = document.getElementById('time-current');
            const timeTotal = document.getElementById('time-total');
            const playerContainer = document.getElementById('audio-player-container');
            const pCoverImg = document.getElementById('player-cover-img');
            const pCoverPlaceholder = document.getElementById('player-cover-placeholder');
            
            let currentPodcastId = null;

            const formatTime = (seconds) => {
                if (isNaN(seconds)) return "0:00";
                const mins = Math.floor(seconds / 60);
                const secs = Math.floor(seconds % 60);
                return `${mins}:${secs < 10 ? '0' : ''}${secs}`;
            };

            // Captura o clique no play-overlay do card real publicado
            document.querySelectorAll('.play-overlay').forEach(overlay => {
                overlay.addEventListener('click', function() {
                    const card = this.closest('.podcast-card');
                    const title = card.querySelector('h6').innerText;
                    
                    // Lendo as propriedades do Banco injetadas nas tags data-
                    const audioUrl = this.getAttribute('data-audio'); 
                    const author = this.getAttribute('data-author');
                    const coverUrl = this.getAttribute('data-cover');
                    
                    document.getElementById('player-title').innerText = title;
                    document.getElementById('player-author').innerText = author;
                    
                    if (coverUrl && !coverUrl.includes('default-cover.png')) {
                        pCoverImg.src = coverUrl;
                        pCoverImg.style.display = 'block';
                        pCoverPlaceholder.style.display = 'none';
                    } else {
                        pCoverImg.style.display = 'none';
                        pCoverPlaceholder.style.display = 'block';
                    }

                    audio.src = audioUrl;
                    currentPodcastId = card.querySelector('.favorite-btn').getAttribute('data-id'); 
                    
                    playerContainer.style.display = 'block'; 
                    audio.play();
                    playIcon.classList.replace('bi-play-fill', 'bi-pause-fill');
                });
            });

            playPauseBtn.addEventListener('click', () => {
                if (audio.paused) {
                    audio.play();
                    playIcon.classList.replace('bi-play-fill', 'bi-pause-fill');
                } else {
                    audio.pause();
                    playIcon.classList.replace('bi-pause-fill', 'bi-play-fill');
                }
            });

            audio.addEventListener('timeupdate', () => {
                seekBar.value = (audio.currentTime / audio.duration) * 100 || 0;
                timeCurrent.innerText = formatTime(audio.currentTime);
            });

            audio.addEventListener('loadedmetadata', () => {
                timeTotal.innerText = formatTime(audio.duration);
            });

            seekBar.addEventListener('input', () => {
                audio.currentTime = (seekBar.value / 100) * audio.duration;
            });

            volumeBar.addEventListener('input', () => {
                audio.volume = volumeBar.value;
            });

            // Sincroniza progresso com o banco a cada 10 segundos
            setInterval(async () => {
                if (!audio.paused && currentPodcastId) {
                    try {
                        await fetch('/api/progress/save', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ 
                                podcastId: currentPodcastId, 
                                currentTime: audio.currentTime 
                            })
                        });
                    } catch (error) {
                        console.error('Erro ao sincronizar progresso:', error);
                    }
                }
            }, 10000);
        });
    </script>
</body>
</html>