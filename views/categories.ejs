<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | PodWave</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/stylesheets/style.css">
    <style>
        .category-card {
            border-radius: 12px;
            transition: transform 0.2s, box-shadow 0.2s;
            cursor: pointer;
            height: 140px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-decoration: none;
            color: white;
        }
        .category-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.15);
            color: white;
        }
        .category-card i { font-size: 2.5rem; margin-bottom: 10px; }
    </style>
</head>

<body class="bg-light">

    <!-- Navbar Base -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white sticky-top shadow-sm">
        <div class="container-fluid px-lg-5">
            <a class="navbar-brand fw-bold text-primary" href="/feed"><i class="bi bi-mic-fill"></i> PODWAVE</a>
            <div class="d-flex align-items-center ms-auto">
                <div class="dropdown">
                    <a href="#" class="d-block link-dark text-decoration-none dropdown-toggle" id="dropdownUser" data-bs-toggle="dropdown" aria-expanded="false">
                        <span class="me-2 d-none d-md-inline small fw-semibold">@<%= user.username %></span>
<img src="<%= (user.profilePicture && user.profilePicture !== 'default-profile.png') ? '/uploads/profiles/' + user.profilePicture : 'https://ui-avatars.com/api/?name=' + user.username + '&background=4f46e5&color=fff' %>" 
     alt="Avatar" width="32" height="32" class="rounded-circle object-fit-cover bg-secondary">                    </a>
                    <ul class="dropdown-menu dropdown-menu-end text-small shadow border-0 mt-2">
                        <li><a class="dropdown-item py-2" href="/profile/edit"><i class="bi bi-person me-2"></i> Meu Perfil</a></li>
                        <li><a class="dropdown-item py-2 text-danger" href="/logout"><i class="bi bi-box-arrow-right me-2"></i> Sair</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </nav>

    <div class="container-fluid px-lg-5">
        <div class="row">
            <!-- Sidebar -->
            <aside class="col-md-3 col-lg-2 d-none d-md-block sidebar py-4 bg-white min-vh-100 border-end">
                <nav class="nav flex-column">
                    <a class="nav-link text-dark" href="/feed"><i class="bi bi-house-door me-2"></i> Início</a>
                    <a class="nav-link active fw-bold text-primary" href="/categories"><i class="bi bi-grid-fill me-2"></i> Categorias</a>
                    <a class="nav-link text-dark" href="/explore"><i class="bi bi-compass me-2"></i> Explorar</a>
                    <hr>
                    <p class="small text-muted px-3 mb-2 fw-bold text-uppercase">Sua Biblioteca</p>
                    <a class="nav-link text-dark py-2" href="/continue"><i class="bi bi-play-circle me-2"></i> Continuar Ouvindo</a>
                    <a class="nav-link text-dark py-2" href="/favorites"><i class="bi bi-heart me-2"></i> Favoritos</a>
                    <a class="nav-link text-dark py-2" href="/history"><i class="bi bi-clock-history me-2"></i> Histórico</a>
                </nav>
            </aside>

            <!-- Main Content: Categorias -->
            <main class="col-12 col-md-9 col-lg-10 py-4">
                <h4 class="fw-bold mb-4">Navegar por Categorias</h4>
                
                <div class="row g-4">
                    <div class="col-6 col-md-4 col-lg-3">
                        <a href="/explore?cat=tech" class="category-card shadow-sm" style="background-color: #0d6efd;">
                            <i class="bi bi-laptop"></i> <h6 class="fw-bold mb-0">Tecnologia</h6>
                        </a>
                    </div>
                    <div class="col-6 col-md-4 col-lg-3">
                        <a href="/explore?cat=business" class="category-card shadow-sm" style="background-color: #198754;">
                            <i class="bi bi-briefcase"></i> <h6 class="fw-bold mb-0">Negócios</h6>
                        </a>
                    </div>
                    <div class="col-6 col-md-4 col-lg-3">
                        <a href="/explore?cat=games" class="category-card shadow-sm" style="background-color: #dc3545;">
                            <i class="bi bi-controller"></i> <h6 class="fw-bold mb-0">Games</h6>
                        </a>
                    </div>
                    <div class="col-6 col-md-4 col-lg-3">
                        <a href="/explore?cat=comedy" class="category-card shadow-sm" style="background-color: #ffc107; color: #000;">
                            <i class="bi bi-emoji-laughing"></i> <h6 class="fw-bold mb-0">Comédia</h6>
                        </a>
                    </div>
                    <div class="col-6 col-md-4 col-lg-3">
                        <a href="/explore?cat=education" class="category-card shadow-sm" style="background-color: #6f42c1;">
                            <i class="bi bi-book"></i> <h6 class="fw-bold mb-0">Educação</h6>
                        </a>
                    </div>
                    <div class="col-6 col-md-4 col-lg-3">
                        <a href="/explore?cat=science" class="category-card shadow-sm" style="background-color: #0dcaf0;">
                            <i class="bi bi-stars"></i> <h6 class="fw-bold mb-0">Ciência</h6>
                        </a>
                    </div>
                </div>
            </main>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html> 