<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | PodWave</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>

<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-light bg-white sticky-top shadow-sm">
        <div class="container-fluid px-lg-5">
            <a class="navbar-brand fw-bold text-primary" href="/feed"><i class="bi bi-mic-fill"></i> PODWAVE</a>
            <div class="d-flex align-items-center ms-auto">
                <div class="dropdown">
                    <a href="#" class="d-block link-dark text-decoration-none dropdown-toggle" id="dropdownUser" data-bs-toggle="dropdown" aria-expanded="false">
                        <span class="me-2 d-none d-md-inline small fw-semibold">@<%= user.username %></span>
<img src="<%= (user.profilePicture && user.profilePicture !== 'default-profile.png') ? '/uploads/profiles/' + user.profilePicture : 'https://ui-avatars.com/api/?name=' + user.username + '&background=4f46e5&color=fff' %>" 
     alt="Avatar" width="32" height="32" class="rounded-circle object-fit-cover bg-secondary">                    </a>
                    <ul class="dropdown-menu dropdown-menu-end text-small shadow border-0 mt-2">
                        <li><a class="dropdown-item py-2" href="/profile/edit"><i class="bi bi-person me-2"></i> Meu Perfil</a></li>
                        <li><a class="dropdown-item py-2 text-danger" href="/logout"><i class="bi bi-box-arrow-right me-2"></i> Sair</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </nav>

    <div class="container-fluid px-lg-5">
        <div class="row">
            <aside class="col-md-3 col-lg-2 d-none d-md-block sidebar py-4 bg-white min-vh-100 border-end">
                <nav class="nav flex-column">
                    <a class="nav-link text-dark" href="/feed"><i class="bi bi-house-door me-2"></i> Início</a>
                    <a class="nav-link text-dark" href="/categories"><i class="bi bi-grid me-2"></i> Categorias</a>
                    <hr>
                    <p class="small text-muted px-3 mb-2 fw-bold text-uppercase">Sua Biblioteca</p>
                    <a class="nav-link text-dark py-2" href="/continue"><i class="bi bi-play-circle me-2"></i> Continuar Ouvindo</a>
                    <a class="nav-link text-dark py-2" href="/favorites"><i class="bi bi-heart me-2"></i> Favoritos</a>
                    <a class="nav-link active fw-bold text-secondary py-2" href="/history"><i class="bi bi-clock-history me-2"></i> Histórico</a>
                </nav>
            </aside>

            <main class="col-12 col-md-9 col-lg-10 py-4">
                <div class="d-flex align-items-center justify-content-between mb-4 pb-2 border-bottom">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-clock-history fs-3 text-secondary me-3"></i>
                        <h4 class="fw-bold mb-0">Histórico de Audição</h4>
                    </div>
                    <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i> Limpar Histórico</button>
                </div>

                <div class="list-group list-group-flush shadow-sm rounded-3">
                    
                    <h6 class="mt-3 mb-2 text-muted fw-bold small text-uppercase">Hoje</h6>
                    <div class="list-group-item d-flex justify-content-between align-items-center py-3 border bg-white mb-2 rounded">
                        <div class="d-flex align-items-center">
                            <div class="bg-dark rounded flex-shrink-0 d-flex justify-content-center align-items-center me-3" style="width: 60px; height: 60px;">
                                <i class="bi bi-code-slash text-info fs-4"></i>
                            </div>
                            <div>
                                <h6 class="mb-0 fw-bold">Hipsters #400 - O Futuro do Front-end</h6>
                                <small class="text-muted">Hipsters Ponto Tech • Parou em 30:15</small>
                            </div>
                        </div>
                        <div class="d-none d-md-block">
                            <button class="btn btn-light border rounded-circle"><i class="bi bi-play-fill"></i></button>
                        </div>
                    </div>

                    <h6 class="mt-4 mb-2 text-muted fw-bold small text-uppercase">Ontem</h6>
                    <div class="list-group-item d-flex justify-content-between align-items-center py-3 border bg-white mb-2 rounded">
                        <div class="d-flex align-items-center">
                            <div class="bg-dark rounded flex-shrink-0 d-flex justify-content-center align-items-center me-3" style="width: 60px; height: 60px;">
                                <i class="bi bi-rocket-takeoff text-warning fs-4"></i>
                            </div>
                            <div>
                                <h6 class="mb-0 fw-bold text-muted">NerdCast 920 - A Inteligência Artificial Vai Dominar o Mundo?</h6>
                                <small class="text-muted">Jovem Nerd • Concluído</small>
                            </div>
                        </div>
                        <div class="d-none d-md-block">
                            <span class="badge bg-success"><i class="bi bi-check-circle"></i> Visto</span>
                        </div>
                    </div>
                    
                </div>
            </main>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>