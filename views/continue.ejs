<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | PodWave</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/stylesheets/style.css">
    <style>
        .podcast-card { border: 1px solid #eaeaea; border-radius: 10px; overflow: hidden; transition: transform 0.2s; background-color: #fff; }
        .podcast-card:hover { transform: translateY(-4px); box-shadow: 0 8px 15px rgba(0,0,0,0.05); }
        .cover-placeholder { aspect-ratio: 1 / 1; display: flex; align-items: center; justify-content: center; position: relative; color: white; font-size: 3rem; background-color: #212529;}
    </style>
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-light bg-white sticky-top shadow-sm">
        <div class="container-fluid px-lg-5">
            <a class="navbar-brand fw-bold text-primary" href="/feed"><i class="bi bi-mic-fill"></i> PODWAVE</a>
            <div class="d-flex align-items-center ms-auto">
                <div class="dropdown">
                    <a href="#" class="d-block link-dark text-decoration-none dropdown-toggle" data-bs-toggle="dropdown">
                        <span class="me-2 d-none d-md-inline small fw-semibold">@<%= user.username %></span>
                        <img src="<%= (user.profilePicture && user.profilePicture !== 'default-profile.png') ? '/uploads/profiles/' + user.profilePicture : 'https://ui-avatars.com/api/?name=' + user.username + '&background=4f46e5&color=fff' %>" alt="Avatar" width="32" height="32" class="rounded-circle object-fit-cover bg-secondary">
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end text-small shadow border-0 mt-2">
                        <li><a class="dropdown-item py-2" href="/profile/edit"><i class="bi bi-person me-2"></i> Meu Perfil</a></li>
                        <li><a class="dropdown-item py-2 text-danger" href="/logout"><i class="bi bi-box-arrow-right me-2"></i> Sair</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </nav>

    <div class="container-fluid px-lg-5">
        <div class="row">
            <aside class="col-md-3 col-lg-2 d-none d-md-block sidebar py-4 bg-white min-vh-100 border-end">
                <nav class="nav flex-column">
                    <a class="nav-link text-dark" href="/feed"><i class="bi bi-house-door me-2"></i> Início</a>
                    <a class="nav-link text-dark" href="/categories"><i class="bi bi-grid me-2"></i> Categorias</a>
                    <hr>
                    <p class="small text-muted px-3 mb-2 fw-bold text-uppercase">Sua Biblioteca</p>
                    <a class="nav-link active fw-bold text-primary" href="/continue"><i class="bi bi-play-circle-fill me-2"></i> Continuar Ouvindo</a>
                    <a class="nav-link text-dark py-2" href="/favorites"><i class="bi bi-heart me-2"></i> Favoritos</a>
                    <a class="nav-link text-dark py-2" href="/history"><i class="bi bi-clock-history me-2"></i> Histórico</a>
                </nav>
            </aside>

            <main class="col-12 col-md-9 col-lg-10 py-4">
                <div class="d-flex align-items-center mb-4 pb-2 border-bottom">
                    <i class="bi bi-play-circle-fill fs-3 text-primary me-3"></i>
                    <h4 class="fw-bold mb-0">Continuar Ouvindo</h4>
                </div>

                <div class="row g-4">
                    <% if (typeof podcasts !== 'undefined' && podcasts.length > 0) { %>
                        <% podcasts.forEach(podcast => { %>
                            <div class="col-12 col-sm-6 col-md-4 col-xl-3">
                                <div class="podcast-card">
                                    <div class="cover-placeholder" style="background-image: url('<%= podcast.coverUrl ? '/uploads/covers/' + podcast.coverUrl : '' %>'); background-size: cover; background-position: center;">
                                        <% if (!podcast.coverUrl) { %><i class="bi bi-mic-fill"></i><% } %>
                                    </div>
                                    <div class="p-3">
                                        <h6 class="text-truncate mb-1 fw-bold"><%= podcast.title %></h6>
                                        <p class="text-muted small mb-3">Parou em: <%= Math.floor(podcast.currentTime / 60) %> min <%= Math.floor(podcast.currentTime % 60) %> seg</p>
                                        
                                        <button class="btn btn-primary w-100 rounded-pill fw-semibold shadow-sm play-overlay" 
                                                data-audio="/uploads/audio/<%= podcast.audioUrl %>" 
                                                data-time="<%= podcast.currentTime %>"
                                                data-title="<%= podcast.title %>"
                                                data-id="<%= podcast.id %>">
                                            <i class="bi bi-play-fill me-1"></i> Retomar
                                        </button>
                                    </div>
                                </div>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div class="col-12 text-center py-5">
                            <i class="bi bi-headphones text-muted" style="font-size: 3rem;"></i>
                            <p class="text-muted mt-3">Você não tem nenhum episódio em andamento.</p>
                        </div>
                    <% } %>
                </div>
            </main>
        </div>
    </div>

    <div class="fixed-bottom bg-white border-top shadow-lg p-3" id="audio-player-container" style="display: none; z-index: 1050;">
        <div class="container-fluid px-lg-5 d-flex align-items-center justify-content-center gap-4">
            <h6 id="player-title" class="fw-bold mb-0" style="width: 20%; text-align: right;"></h6>
            <audio id="main-audio" controls style="width: 50%;"></audio>
            <button class="btn btn-danger" onclick="document.getElementById('audio-player-container').style.display='none'; document.getElementById('main-audio').pause();">Fechar Player</button>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const audio = document.getElementById('main-audio');
            const playerContainer = document.getElementById('audio-player-container');
            let currentPodcastId = null;

            // Lógica que pega o botão "Retomar" da tela de Continuar Ouvindo
            document.querySelectorAll('.play-overlay').forEach(btn => {
                btn.addEventListener('click', function() {
                    const audioUrl = this.getAttribute('data-audio');
                    const savedTime = parseFloat(this.getAttribute('data-time')) || 0; 
                    currentPodcastId = this.getAttribute('data-id');
                    
                    document.getElementById('player-title').innerText = this.getAttribute('data-title');
                    
                    audio.src = audioUrl;
                    playerContainer.style.display = 'block';
                    
                    // FORÇA O NAVEGADOR A PULAR O TEMPO ANTES DO PLAY!
                    const setTimeAndPlay = () => {
                        audio.currentTime = savedTime;
                        audio.play();
                        audio.removeEventListener('canplay', setTimeAndPlay);
                    };
                    
                    audio.addEventListener('canplay', setTimeAndPlay);
                    audio.load();
                });
            });

            // Mantém salvando se ele continuar escutando
            setInterval(async () => {
                if (!audio.paused && currentPodcastId) {
                    try {
                        await fetch('/api/progress/save', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ 
                                podcastId: currentPodcastId, 
                                currentTime: audio.currentTime 
                            })
                        });
                    } catch (error) {
                        console.error('Erro:', error);
                    }
                }
            }, 5000);
        });
    </script>
</body>
</html>