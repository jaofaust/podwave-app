<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PodWave | <%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <style>
        body { background-color: #f8f9fa; }
        .podcast-card { transition: transform 0.2s, box-shadow 0.2s; border-radius: 12px; overflow: hidden; border: 1px solid #eaeaea; background: #fff; }
        .podcast-card:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.08); }
        .cover-placeholder { background-color: #212529; color: white; height: 180px; display: flex; align-items: center; justify-content: center; position: relative; }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-light bg-white sticky-top shadow-sm py-3">
        <div class="container">
            <a class="navbar-brand fw-bold text-primary" href="/">
                <i class="bi bi-mic-fill me-1"></i> PodWave
            </a>
            <div class="ms-auto">
                <% if (typeof user !== 'undefined' && user) { %>
                    <a class="btn btn-outline-primary px-4 fw-semibold" href="/admin/dashboard">Painel Geral</a>
                <% } else { %>
                    <a class="btn btn-primary text-white px-4 fw-semibold" href="/login">Entrar</a>
                <% } %>
            </div>
        </div>
    </nav>

    <main class="container my-5">
        <h4 class="fw-bold mb-4">Episódios Recentes</h4>
        <div class="row g-4">
            <% if (typeof podcasts !== 'undefined' && podcasts.length > 0) { %>
                <% podcasts.forEach(podcast => { %>
                    <div class="col-12 col-sm-6 col-lg-3">
                        <div class="podcast-card">
                            <div class="cover-placeholder" style="background-image: url('<%= podcast.coverUrl ? '/uploads/covers/' + podcast.coverUrl : '' %>'); background-size: cover; background-position: center; height: 180px;">
                                <% if (!podcast.coverUrl) { %>
                                    <i class="bi bi-mic-fill fs-1 text-light"></i>
                                <% } %>
                            </div>
                            <div class="p-3">
                                <h6 class="text-truncate mb-1 fw-bold"><%= podcast.title %></h6>
                                <p class="text-muted small mb-2"><%= podcast.author %></p>
                                <audio controls class="w-100 mt-2" style="height: 35px;">
                                    <source src="/uploads/audio/<%= podcast.audioUrl %>" type="audio/mpeg">
                                    Seu navegador não suporta a execução do player.
                                </audio>
                            </div>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <div class="col-12 text-center py-5">
                    <p class="text-muted">Nenhum episódio publicado ainda.</p>
                </div>
            <% } %>
        </div>
    </main>
</body>
</html>