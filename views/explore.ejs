<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | PodWave</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/stylesheets/style.css">
    <style>
        .podcast-card { border: 1px solid #eaeaea; border-radius: 10px; overflow: hidden; transition: transform 0.2s; background-color: #fff; }
        .podcast-card:hover { transform: translateY(-4px); box-shadow: 0 8px 15px rgba(0,0,0,0.05); }
        .cover-placeholder { aspect-ratio: 1 / 1; display: flex; align-items: center; justify-content: center; position: relative; color: white; font-size: 3rem; }
    </style>
</head>

<body class="bg-light">

    <!-- Navbar Base -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white sticky-top shadow-sm">
        <div class="container-fluid px-lg-5">
            <a class="navbar-brand fw-bold text-primary" href="/feed"><i class="bi bi-mic-fill"></i> PODWAVE</a>
            <div class="d-flex align-items-center ms-auto">
                <div class="dropdown">
                    <a href="#" class="d-block link-dark text-decoration-none dropdown-toggle" id="dropdownUser" data-bs-toggle="dropdown" aria-expanded="false">
                        <span class="me-2 d-none d-md-inline small fw-semibold">@<%= user.username %></span>
<img src="<%= (user.profilePicture && user.profilePicture !== 'default-profile.png') ? '/uploads/profiles/' + user.profilePicture : 'https://ui-avatars.com/api/?name=' + user.username + '&background=4f46e5&color=fff' %>" 
     alt="Avatar" width="32" height="32" class="rounded-circle object-fit-cover bg-secondary">                    </a>
                </div>
            </div>
        </div>
    </nav>

    <div class="container-fluid px-lg-5">
        <div class="row">
            <!-- Sidebar -->
            <aside class="col-md-3 col-lg-2 d-none d-md-block sidebar py-4 bg-white min-vh-100 border-end">
                <nav class="nav flex-column">
                    <a class="nav-link text-dark" href="/feed"><i class="bi bi-house-door me-2"></i> Início</a>
                    <a class="nav-link text-dark" href="/categories"><i class="bi bi-grid me-2"></i> Categorias</a>
                    <a class="nav-link active fw-bold text-primary" href="/explore"><i class="bi bi-compass-fill me-2"></i> Explorar</a>
                    <hr>
                    <p class="small text-muted px-3 mb-2 fw-bold text-uppercase">Sua Biblioteca</p>
                    <a class="nav-link text-dark py-2" href="/continue"><i class="bi bi-play-circle me-2"></i> Continuar Ouvindo</a>
                    <a class="nav-link text-dark py-2" href="/favorites"><i class="bi bi-heart me-2"></i> Favoritos</a>
                    <a class="nav-link text-dark py-2" href="/history"><i class="bi bi-clock-history me-2"></i> Histórico</a>
                </nav>
            </aside>

            <!-- Main Content: Explorar -->
            <main class="col-12 col-md-9 col-lg-10 py-4">
                <h4 class="fw-bold mb-4"><i class="bi bi-fire text-danger me-2"></i> Em Alta no Brasil</h4>
                
                <div class="row g-4 mb-5">
                    <!-- Episódio Em Alta 1 -->
                    <div class="col-12 col-sm-6 col-md-4 col-xl-3">
                        <div class="podcast-card">
                            <div class="cover-placeholder" style="background-color: #6f42c1;">
                                <i class="bi bi-lightning-charge-fill text-warning"></i>
                                <span class="badge bg-danger position-absolute top-0 start-0 m-2">#1 TOP</span>
                            </div>
                            <div class="p-3">
                                <div class="d-flex justify-content-between align-items-start mb-1">
                                    <h6 class="text-truncate mb-0 fw-bold">O que é Web3?</h6>
                                    <!-- NOTA: Adicionamos a classe 'favorite-btn' e 'data-id' aqui para o JS -->
                                    <i class="bi bi-heart text-muted favorite-btn" data-id="101" style="cursor: pointer;"></i>
                                </div>
                                <div class="text-muted small mb-2">DevCast Brasil</div>
                            </div>
                        </div>
                    </div>
                </div>

            </main>
        </div>
    </div>

    <!-- SCRIPT DE FAVORITOS (Coloque isso no final de todas as páginas que têm os cards) -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Seleciona todos os ícones de coração que possuem a classe 'favorite-btn'
            const favoriteButtons = document.querySelectorAll('.favorite-btn');

            favoriteButtons.forEach(btn => {
                btn.addEventListener('click', async function() {
                    const podcastId = this.getAttribute('data-id'); // Pega o ID do podcast do HTML
                    const isFavorited = this.classList.contains('bi-heart-fill');

                    // 1. EFEITO VISUAL IMEDIATO (Melhora a experiência do usuário)
                    if (isFavorited) {
                        this.classList.remove('bi-heart-fill', 'text-danger');
                        this.classList.add('bi-heart', 'text-muted');
                    } else {
                        this.classList.remove('bi-heart', 'text-muted');
                        this.classList.add('bi-heart-fill', 'text-danger');
                    }

                    // 2. REQUISIÇÃO PARA O BACK-END (Salva a ação no seu Banco de Dados)
                    try {
                        const response = await fetch('/api/favorites/toggle', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ podcastId: podcastId })
                        });

                        const result = await response.json();
                        
                        // Se deu erro no servidor, revertemos a animação visual
                        if (!result.success) {
                            if (isFavorited) {
                                this.classList.remove('bi-heart', 'text-muted');
                                this.classList.add('bi-heart-fill', 'text-danger');
                            } else {
                                this.classList.remove('bi-heart-fill', 'text-danger');
                                this.classList.add('bi-heart', 'text-muted');
                            }
                            alert('Erro ao salvar nos favoritos. Tente novamente.');
                        }
                    } catch (error) {
                        console.error('Erro na comunicação com a API:', error);
                    }
                });
            });
        });
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>